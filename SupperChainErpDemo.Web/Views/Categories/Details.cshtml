@model SupperChainErpDemo.Web.ViewModels.Categories.CategoryDetailsViewModel
@{
    ViewData["Title"] = "View Category";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-14</p>
        <h2>@Model.Category.CategoryName</h2>
        <p>Xem chi tiết category và các product đang thuộc nhóm này.</p>
    </div>
    <div class="action-stack">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Category.CategoryId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</section>

<section class="content-grid">
    <article class="content-panel">
        <h3>Category summary</h3>
        <dl class="detail-grid">
            <dt>Category ID</dt>
            <dd>@Model.Category.CategoryId</dd>
            <dt>SKU Prefix</dt>
            <dd>@Model.Category.SkuPrefix</dd>
            <dt>Status</dt>
            <dd><span class="status-pill @(Model.Category.Status == RecordStatus.Active ? "active" : "inactive")">@Model.Category.Status</span></dd>
            <dt>Description</dt>
            <dd>@Model.Category.Description</dd>
        </dl>
    </article>

    <article class="content-panel">
        <h3>Mapped products</h3>
        <ul class="plain-list">
            @foreach (var product in Model.Products)
            {
                <li>@product.ProductName - @product.Sku</li>
            }
        </ul>
    </article>
</section>
