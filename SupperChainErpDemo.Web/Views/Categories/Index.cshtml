@model SupperChainErpDemo.Web.ViewModels.Categories.CategoryIndexViewModel
@{
    ViewData["Title"] = "Categories";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-13 to UC-16</p>
        <h2>Category management</h2>
        <p>Quản lý nhóm hàng, SKU prefix và phụ thuộc sản phẩm trước khi deactive.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Category</a>
</section>

<section class="content-panel">
    <form method="get" class="toolbar">
        <select name="statusFilter" class="form-select">
            <option value="">All statuses</option>
            <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
            <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
    </form>

    <div class="table-responsive mt-4">
        <table class="table table-app align-middle">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>SKU Prefix</th>
                    <th>Products</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model.Categories)
                {
                    <tr>
                        <td>
                            <strong>@category.CategoryName</strong>
                            <div class="cell-muted">@category.Description</div>
                        </td>
                        <td>@category.SkuPrefix</td>
                        <td>@Model.ProductCountByCategory.GetValueOrDefault(category.CategoryId, 0)</td>
                        <td><span class="status-pill @(category.Status == RecordStatus.Active ? "active" : "inactive")">@category.Status</span></td>
                        <td class="text-end">
                            <div class="action-stack">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@category.CategoryId">View</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@category.CategoryId">Edit</a>
                                <form method="post" asp-action="ChangeStatus">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@category.CategoryId" />
                                    <input type="hidden" name="status" value="@(category.Status == RecordStatus.Active ? RecordStatus.Inactive : RecordStatus.Active)" />
                                    <button class="btn btn-sm @(category.Status == RecordStatus.Active ? "btn-outline-danger" : "btn-outline-success")" type="submit">
                                        @(category.Status == RecordStatus.Active ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
