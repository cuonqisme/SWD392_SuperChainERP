@model SupperChainErpDemo.Web.ViewModels.TransferNotes.TransferNoteFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-lg-6">
        <label asp-for="SourceLocId" class="form-label"></label>
        <select asp-for="SourceLocId" asp-items="Model.LocationOptions" class="form-select">
            <option value="">Select a source location</option>
        </select>
        <span asp-validation-for="SourceLocId" class="text-danger"></span>
    </div>
    <div class="col-lg-6">
        <label asp-for="DestinationLocId" class="form-label"></label>
        <select asp-for="DestinationLocId" asp-items="Model.LocationOptions" class="form-select">
            <option value="">Select a destination location</option>
        </select>
        <span asp-validation-for="DestinationLocId" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="Note" class="form-label"></label>
        <textarea asp-for="Note" class="form-control" rows="3"></textarea>
        <span asp-validation-for="Note" class="text-danger"></span>
    </div>
</div>

@if (Model.InventoryWarnings.Count > 0)
{
    <div class="app-alert mt-4">
        <div>
            <strong>Inventory snapshot warning</strong>
            <span>The request can still be saved, but manager review should consider the current source stock.</span>
            <ul class="plain-list mt-2">
                @foreach (var warning in Model.InventoryWarnings)
                {
                    <li>@warning</li>
                }
            </ul>
        </div>
    </div>
}

<div class="section-heading mt-4">
    <div>
        <p class="eyebrow">TransferInteraction</p>
        <h3>Transfer items</h3>
    </div>
    <span class="app-chip">Minimum 1 line</span>
</div>

<div class="table-responsive mt-3">
    <table class="table table-app align-middle">
        <thead>
            <tr>
                <th style="width: 55%;">Product</th>
                <th style="width: 20%;">Quantity</th>
                <th style="width: 25%;">Source availability</th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Model.Items.Count; i++)
            {
                <tr>
                    <td>
                        <select asp-for="Items[i].ProductId" asp-items="Model.ProductOptions" class="form-select">
                            <option value="">Select a product</option>
                        </select>
                        <span asp-validation-for="Items[i].ProductId" class="text-danger"></span>
                    </td>
                    <td>
                        <input asp-for="Items[i].Quantity" class="form-control" />
                        <span asp-validation-for="Items[i].Quantity" class="text-danger"></span>
                    </td>
                    <td>
                        @(Model.Items[i].AvailableQuantity?.ToString() ?? "-")
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
