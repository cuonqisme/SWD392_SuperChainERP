@model SupperChainErpDemo.Web.ViewModels.TransferNotes.TransferNoteIndexViewModel
@using SupperChainErpDemo.Web.Models
@{
    ViewData["Title"] = "Transfer Notes";

    string statusClass(TransferNoteStatus status) => status switch
    {
        TransferNoteStatus.Draft => "app-chip",
        TransferNoteStatus.Approved => "status-pill active",
        TransferNoteStatus.TransferOutConfirmed => "status-pill active",
        TransferNoteStatus.Rejected => "status-pill inactive",
        _ => "app-chip"
    };
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-41 to UC-45</p>
        <h2>Transfer note management</h2>
        <p>Create, review, approve, and confirm outbound transfer requests between internal locations.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Transfer Note</a>
</section>

<section class="content-panel">
    <form method="get" class="toolbar toolbar-wide">
        <input name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Search by transfer no or note" />
        <select name="sourceFilter" class="form-select">
            <option value="">All source locations</option>
            @foreach (var item in Model.LocationOptions)
            {
                <option value="@item.Value" selected="@(Model.SourceFilter == item.Value)">@item.Text</option>
            }
        </select>
        <select name="destinationFilter" class="form-select">
            <option value="">All destination locations</option>
            @foreach (var item in Model.LocationOptions)
            {
                <option value="@item.Value" selected="@(Model.DestinationFilter == item.Value)">@item.Text</option>
            }
        </select>
        <select name="statusFilter" class="form-select">
            <option value="">All statuses</option>
            <option value="Draft" selected="@(Model.StatusFilter == "Draft")">Draft</option>
            <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
            <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
            <option value="TransferOutConfirmed" selected="@(Model.StatusFilter == "TransferOutConfirmed")">Transfer Out Confirmed</option>
        </select>
        <input name="createdFrom" value="@Model.CreatedFrom?.ToString("yyyy-MM-dd")" type="date" class="form-control" />
        <input name="createdTo" value="@Model.CreatedTo?.ToString("yyyy-MM-dd")" type="date" class="form-control" />
        <button class="btn btn-outline-secondary" type="submit">Apply</button>
    </form>

    @if (!string.IsNullOrWhiteSpace(Model.EmptyStateMessage))
    {
        <div class="app-alert mt-4">
            <div>
                <strong>FilterService result</strong>
                <span>@Model.EmptyStateMessage</span>
            </div>
        </div>
    }

    <div class="table-responsive mt-4">
        <table class="table table-app align-middle">
            <thead>
                <tr>
                    <th>Transfer</th>
                    <th>Route</th>
                    <th>Created by</th>
                    <th>Items</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var note in Model.TransferNotes)
                {
                    <tr>
                        <td>
                            <strong>@note.TransferNo</strong>
                            <div class="cell-muted">@note.CreatedDate.ToString("dd MMM yyyy HH:mm")</div>
                        </td>
                        <td>
                            <strong>@note.SourceLocationName</strong>
                            <div class="cell-muted">to @note.DestinationLocationName</div>
                        </td>
                        <td>
                            <strong>@note.CreatedByName</strong>
                            <div class="cell-muted">Approved by @note.ApprovedByName</div>
                        </td>
                        <td>
                            <strong>@note.TotalItems line(s)</strong>
                            <div class="cell-muted">@note.TotalQuantity unit(s)</div>
                        </td>
                        <td><span class="@statusClass(note.Status)">@note.StatusLabel</span></td>
                        <td class="text-end">
                            <div class="action-stack">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@note.TransferNoteId">View</a>
                                @if (note.CanEdit)
                                {
                                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@note.TransferNoteId">Edit</a>
                                }
                                @if (note.CanApprove)
                                {
                                    <form method="post" asp-action="Approve">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@note.TransferNoteId" />
                                        <button class="btn btn-sm btn-success" type="submit">Approve</button>
                                    </form>
                                }
                                @if (note.CanReject)
                                {
                                    <form method="post" asp-action="Reject">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@note.TransferNoteId" />
                                        <input type="hidden" name="reason" value="Rejected during transfer review." />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Reject</button>
                                    </form>
                                }
                                @if (note.CanConfirmTransferOut)
                                {
                                    <form method="post" asp-action="ConfirmTransferOut">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@note.TransferNoteId" />
                                        <button class="btn btn-sm btn-primary" type="submit">Confirm Out</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
