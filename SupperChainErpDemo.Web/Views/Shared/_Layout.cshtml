<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SupperChain ERP Demo</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SupperChainErpDemo.Web.styles.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
    }
    <div class="app-shell">
        <aside class="app-sidebar">
            <a class="brand-mark" asp-controller="Home" asp-action="Index">
                <span class="brand-mark__dot"></span>
                <div>
                    <strong>SupperChain ERP</strong>
                    <small>Release 1.0 demo</small>
                </div>
            </a>

            <div class="sidebar-group">
                <span class="sidebar-label">Core navigation</span>
                <a class="nav-tile @(currentController == "Home" ? "is-active" : null)" asp-controller="Home" asp-action="Index">Dashboard</a>
                <a class="nav-tile @(currentController == "Users" ? "is-active" : null)" asp-controller="Users" asp-action="Index">Users</a>
                <a class="nav-tile @(currentController == "Roles" ? "is-active" : null)" asp-controller="Roles" asp-action="Index">Roles</a>
                <a class="nav-tile @(currentController == "Categories" ? "is-active" : null)" asp-controller="Categories" asp-action="Index">Categories</a>
                <a class="nav-tile @(currentController == "Products" ? "is-active" : null)" asp-controller="Products" asp-action="Index">Products</a>
            </div>

            <div class="sidebar-note">
                <p>Focused scope</p>
                <strong>UC-01 to UC-16</strong>
                <span>Users, Roles, Products, and Categories with create, view, update, and status flows.</span>
            </div>
        </aside>

        <div class="app-main">
            <header class="topbar">
                <div>
                    <p class="eyebrow">MVC + Service Layer</p>
                    <h1>@(ViewData["Title"] ?? "ERP workspace")</h1>
                </div>
                <div class="topbar-panel">
                    <span>Communication-diagram aligned</span>
                    <strong>@DateTime.Now.ToString("dd MMM yyyy")</strong>
                </div>
            </header>

            <main class="page-body">
                @await Html.PartialAsync("_Notification")
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
