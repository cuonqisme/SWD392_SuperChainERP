@model SupperChainErpDemo.Web.ViewModels.Products.ProductDetailsViewModel
@{
    ViewData["Title"] = "View Product";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-10</p>
        <h2>@Model.Product.ProductName</h2>
        <p>Xem thông tin product, category, barcode, pricing và trạng thái.</p>
    </div>
    <div class="action-stack">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Product.ProductId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</section>

<section class="content-grid">
    <article class="content-panel">
        <h3>Product summary</h3>
        <dl class="detail-grid">
            <dt>Product ID</dt>
            <dd>@Model.Product.ProductId</dd>
            <dt>Category</dt>
            <dd>@Model.CategoryName</dd>
            <dt>SKU</dt>
            <dd>@Model.Product.Sku</dd>
            <dt>Barcode</dt>
            <dd>@Model.Product.Barcode</dd>
            <dt>Status</dt>
            <dd><span class="status-pill @(Model.Product.Status == RecordStatus.Active ? "active" : "inactive")">@Model.Product.Status</span></dd>
        </dl>
    </article>

    <article class="content-panel">
        <h3>Commercial data</h3>
        <dl class="detail-grid">
            <dt>Base price</dt>
            <dd>@Model.Product.BasePrice.ToString("N0") VND</dd>
            <dt>Created</dt>
            <dd>@Model.Product.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            <dt>Updated</dt>
            <dd>@Model.Product.UpdatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            <dt>Description</dt>
            <dd>@Model.Product.Description</dd>
        </dl>
    </article>
</section>
