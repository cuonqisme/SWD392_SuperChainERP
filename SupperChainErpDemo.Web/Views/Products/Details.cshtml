@model SupperChainErpDemo.Web.Models.Product
@{
    ViewData["Title"] = "View Product";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-10</p>
        <h2>@Model.ProductName</h2>
        <p>Xem thông tin product, category, barcode, pricing và trạng thái.</p>
    </div>
    <div class="action-stack">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.ProductId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</section>

<section class="content-grid">
    <article class="content-panel">
        <h3>Product summary</h3>
        <dl class="detail-grid">
            <dt>Product ID</dt>
            <dd>@Model.ProductId</dd>
            <dt>Category</dt>
            <dd>@ViewBag.CategoryName</dd>
            <dt>SKU</dt>
            <dd>@Model.Sku</dd>
            <dt>Barcode</dt>
            <dd>@Model.Barcode</dd>
            <dt>Status</dt>
            <dd><span class="status-pill @(Model.Status == RecordStatus.Active ? "active" : "inactive")">@Model.Status</span></dd>
        </dl>
    </article>

    <article class="content-panel">
        <h3>Commercial data</h3>
        <dl class="detail-grid">
            <dt>Base price</dt>
            <dd>@Model.BasePrice.ToString("N0") VND</dd>
            <dt>Created</dt>
            <dd>@Model.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            <dt>Updated</dt>
            <dd>@Model.UpdatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            <dt>Description</dt>
            <dd>@Model.Description</dd>
        </dl>
    </article>
</section>
