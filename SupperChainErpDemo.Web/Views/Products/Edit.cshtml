@model SupperChainErpDemo.Web.ViewModels.Products.ProductFormViewModel
@{
    ViewData["Title"] = "Update Product";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-11</p>
        <h2>Update product</h2>
        <p>Cập nhật mô tả hàng hóa, đổi category nếu cần và đồng bộ lại SKU.</p>
    </div>
</section>

<section class="content-panel">
    <form method="post">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("_Form", Model)
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update Product</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
