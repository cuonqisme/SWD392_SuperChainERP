@model SupperChainErpDemo.Web.ViewModels.Products.ProductIndexViewModel
@{
    ViewData["Title"] = "Products";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-09 to UC-12</p>
        <h2>Product management</h2>
        <p>Thiết lập product master, barcode, price và trạng thái bán hàng.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Product</a>
</section>

<section class="content-panel">
    <form method="get" class="toolbar toolbar-wide">
        <select name="categoryFilter" class="form-select">
            <option value="">All categories</option>
            @foreach (var item in Model.CategoryNames)
            {
                <option value="@item.Key" selected="@(Model.CategoryFilter == item.Key)">@item.Value</option>
            }
        </select>
        <select name="statusFilter" class="form-select">
            <option value="">All statuses</option>
            <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
            <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit">Apply</button>
    </form>

    <div class="table-responsive mt-4">
        <table class="table table-app align-middle">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Barcode</th>
                    <th>Base price</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model.Products)
                {
                    <tr>
                        <td>
                            <strong>@product.ProductName</strong>
                            <div class="cell-muted">@product.Sku</div>
                        </td>
                        <td>@Model.CategoryNames[product.CategoryId]</td>
                        <td>@product.Barcode</td>
                        <td>@product.BasePrice.ToString("N0") VND</td>
                        <td><span class="status-pill @(product.Status == RecordStatus.Active ? "active" : "inactive")">@product.Status</span></td>
                        <td class="text-end">
                            <div class="action-stack">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@product.ProductId">View</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@product.ProductId">Edit</a>
                                <form method="post" asp-action="ChangeStatus">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@product.ProductId" />
                                    <input type="hidden" name="status" value="@(product.Status == RecordStatus.Active ? RecordStatus.Inactive : RecordStatus.Active)" />
                                    <button class="btn btn-sm @(product.Status == RecordStatus.Active ? "btn-outline-danger" : "btn-outline-success")" type="submit">
                                        @(product.Status == RecordStatus.Active ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
