@model SupperChainErpDemo.Web.ViewModels.Users.UserFormViewModel

<div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

<div class="row g-4">
    <div class="col-lg-6">
        <label asp-for="RoleId" class="form-label"></label>
        <select asp-for="RoleId" asp-items="Model.RoleOptions" class="form-select">
            <option value="">Select a role</option>
        </select>
        <span asp-validation-for="RoleId" class="text-danger"></span>
    </div>
    <div class="col-lg-6">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control" />
        <span asp-validation-for="Username" class="text-danger"></span>
    </div>
    <div class="col-lg-6">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control" />
        <small class="form-note">Required on create. Leave blank on edit to keep the current password.</small>
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>
    <div class="col-lg-6">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>
    <div class="col-lg-6">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" class="form-control" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="col-lg-6">
        <label asp-for="Phone" class="form-label"></label>
        <input asp-for="Phone" class="form-control" />
        <span asp-validation-for="Phone" class="text-danger"></span>
    </div>
</div>
