@model SupperChainErpDemo.Web.Models.UserAccount
@{
    ViewData["Title"] = "View User";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-02</p>
        <h2>@Model.FullName</h2>
        <p>Xem thông tin user, role đang gán và trạng thái tài khoản.</p>
    </div>
    <div class="action-stack">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.UserId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</section>

<section class="content-grid">
    <article class="content-panel">
        <h3>Account information</h3>
        <dl class="detail-grid">
            <dt>User ID</dt>
            <dd>@Model.UserId</dd>
            <dt>Username</dt>
            <dd>@Model.Username</dd>
            <dt>Role</dt>
            <dd>@ViewBag.RoleName</dd>
            <dt>Status</dt>
            <dd><span class="status-pill @(Model.Status == RecordStatus.Active ? "active" : "inactive")">@Model.Status</span></dd>
        </dl>
    </article>

    <article class="content-panel">
        <h3>Contact and lifecycle</h3>
        <dl class="detail-grid">
            <dt>Full name</dt>
            <dd>@Model.FullName</dd>
            <dt>Email</dt>
            <dd>@Model.Email</dd>
            <dt>Phone</dt>
            <dd>@Model.Phone</dd>
            <dt>Created</dt>
            <dd>@Model.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            <dt>Updated</dt>
            <dd>@Model.UpdatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </article>
</section>
