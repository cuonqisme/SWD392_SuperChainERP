@model SupperChainErpDemo.Web.ViewModels.Users.UserDetailsViewModel
@{
    ViewData["Title"] = "View User";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-02</p>
        <h2>@Model.User.FullName</h2>
        <p>Xem thông tin user, role đang gán và trạng thái tài khoản.</p>
    </div>
    <div class="action-stack">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.User.UserId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</section>

<section class="content-grid">
    <article class="content-panel">
        <h3>Account information</h3>
        <dl class="detail-grid">
            <dt>User ID</dt>
            <dd>@Model.User.UserId</dd>
            <dt>Username</dt>
            <dd>@Model.User.Username</dd>
            <dt>Role</dt>
            <dd>@Model.RoleName</dd>
            <dt>Status</dt>
            <dd><span class="status-pill @(Model.User.Status == RecordStatus.Active ? "active" : "inactive")">@Model.User.Status</span></dd>
        </dl>
    </article>

    <article class="content-panel">
        <h3>Contact and lifecycle</h3>
        <dl class="detail-grid">
            <dt>Full name</dt>
            <dd>@Model.User.FullName</dd>
            <dt>Email</dt>
            <dd>@Model.User.Email</dd>
            <dt>Phone</dt>
            <dd>@Model.User.Phone</dd>
            <dt>Created</dt>
            <dd>@Model.User.CreatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            <dt>Updated</dt>
            <dd>@Model.User.UpdatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
    </article>
</section>
