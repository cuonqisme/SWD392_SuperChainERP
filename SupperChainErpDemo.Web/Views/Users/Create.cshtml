@model SupperChainErpDemo.Web.ViewModels.Users.UserFormViewModel
@{
    ViewData["Title"] = "Create User";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-01</p>
        <h2>Create user</h2>
        <p>Nhập thông tin tài khoản, validate role và dữ liệu người dùng trước khi lưu.</p>
    </div>
</section>

<section class="content-panel">
    <form method="post">
        @Html.AntiForgeryToken()
        @await Html.PartialAsync("_Form", Model)
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save User</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
