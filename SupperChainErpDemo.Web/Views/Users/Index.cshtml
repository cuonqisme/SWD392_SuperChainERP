@model SupperChainErpDemo.Web.ViewModels.Users.UserIndexViewModel
@{
    ViewData["Title"] = "Users";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-01 to UC-04</p>
        <h2>User management</h2>
        <p>Quản lý tài khoản người dùng theo role, xem danh sách, cập nhật hồ sơ và đổi trạng thái.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create User</a>
</section>

<section class="content-panel">
    <form method="get" class="toolbar toolbar-wide">
        <input class="form-control" type="text" name="keyword" value="@Model.Keyword" placeholder="Search username, full name, email..." />
        <select name="statusFilter" class="form-select">
            <option value="">All statuses</option>
            <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
            <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit">Apply</button>
    </form>

    <div class="table-responsive mt-4">
        <table class="table table-app align-middle">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Role</th>
                    <th>Contact</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>
                            <strong>@user.FullName</strong>
                            <div class="cell-muted">@user.Username</div>
                        </td>
                        <td>@Model.RoleNames[user.RoleId]</td>
                        <td>
                            <div>@user.Email</div>
                            <div class="cell-muted">@user.Phone</div>
                        </td>
                        <td><span class="status-pill @(user.Status == RecordStatus.Active ? "active" : "inactive")">@user.Status</span></td>
                        <td class="text-end">
                            <div class="action-stack">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@user.UserId">View</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.UserId">Edit</a>
                                <form method="post" asp-action="ChangeStatus">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@user.UserId" />
                                    <input type="hidden" name="status" value="@(user.Status == RecordStatus.Active ? RecordStatus.Inactive : RecordStatus.Active)" />
                                    <button class="btn btn-sm @(user.Status == RecordStatus.Active ? "btn-outline-danger" : "btn-outline-success")" type="submit">
                                        @(user.Status == RecordStatus.Active ? "Deactivate" : "Activate")
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
