@model SupperChainErpDemo.Web.ViewModels.Roles.RoleIndexViewModel
@{
    ViewData["Title"] = "Roles";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-05 to UC-08</p>
        <h2>Role management</h2>
        <p>Tạo vai trò, xem chi tiết quyền, cập nhật role và deactive theo business rule.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create Role</a>
</section>

<section class="content-panel">
    <form method="get" class="toolbar">
        <select name="statusFilter" class="form-select">
            <option value="">All statuses</option>
            <option value="Active" selected="@(Model.StatusFilter == "Active")">Active</option>
            <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive</option>
        </select>
        <button class="btn btn-outline-secondary" type="submit">Filter</button>
    </form>

    <div class="table-responsive mt-4">
        <table class="table table-app align-middle">
            <thead>
                <tr>
                    <th>Role</th>
                    <th>Description</th>
                    <th>Permissions</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var role in Model.Roles)
                {
                    <tr>
                        <td>
                            <strong>@role.RoleName</strong>
                            <div class="cell-muted">@role.RoleId</div>
                        </td>
                        <td>@role.Description</td>
                        <td>@role.Permissions.Count permission(s)</td>
                        <td>
                            <span class="status-pill @(role.Status == RecordStatus.Active ? "active" : "inactive")">@role.Status</span>
                        </td>
                        <td class="text-end">
                            <div class="action-stack">
                                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@role.RoleId">View</a>
                                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@role.RoleId">Edit</a>
                                @if (role.Status == RecordStatus.Active)
                                {
                                    <form method="post" asp-action="Deactivate">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@role.RoleId" />
                                        <button class="btn btn-sm btn-outline-danger" type="submit">Deactivate</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
