@model SupperChainErpDemo.Web.Models.Role
@{
    ViewData["Title"] = "View Role";
}

<section class="page-intro">
    <div>
        <p class="eyebrow">UC-06</p>
        <h2>@Model.RoleName</h2>
        <p>Xem chi tiết role, danh sách quyền và trạng thái hiện tại.</p>
    </div>
    <div class="action-stack">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.RoleId">Edit</a>
        <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
    </div>
</section>

<section class="content-grid">
    <article class="content-panel">
        <h3>Role summary</h3>
        <dl class="detail-grid">
            <dt>Role ID</dt>
            <dd>@Model.RoleId</dd>
            <dt>Status</dt>
            <dd><span class="status-pill @(Model.Status == RecordStatus.Active ? "active" : "inactive")">@Model.Status</span></dd>
            <dt>Updated</dt>
            <dd>@Model.UpdatedDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</dd>
            <dt>Description</dt>
            <dd>@Model.Description</dd>
        </dl>
    </article>

    <article class="content-panel">
        <h3>Permission set</h3>
        <div class="chip-grid">
            @foreach (var permission in Model.Permissions)
            {
                <span class="app-chip">@permission</span>
            }
        </div>
    </article>
</section>
